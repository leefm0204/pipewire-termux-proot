# This is the build file for project "pipewire"
# It is autogenerated by the Meson build system.
# Do not edit by hand.

ninja_required_version = 1.8.2

# Rules for module scanning.

# Rules for compiling.

rule c_COMPILER_FOR_BUILD
 command = cc $ARGS -MD -MQ $out -MF $DEPFILE -o $out -c $in
 deps = gcc
 depfile = $DEPFILE_UNQUOTED
 description = Compiling C object $out

rule c_COMPILER
 command = clang $ARGS -MD -MQ $out -MF $DEPFILE -o $out -c $in
 deps = gcc
 depfile = $DEPFILE_UNQUOTED
 description = Compiling C object $out

rule cpp_COMPILER
 command = clang++ $ARGS -MD -MQ $out -MF $DEPFILE -o $out -c $in
 deps = gcc
 depfile = $DEPFILE_UNQUOTED
 description = Compiling C++ object $out

# Rules for linking.

rule STATIC_LINKER
 command = rm -f $out && llvm-ar $LINK_ARGS $out $in
 description = Linking static target $out

rule c_LINKER_FOR_BUILD
 command = cc $ARGS -o $out $in $LINK_ARGS
 description = Linking target $out

rule c_LINKER
 command = clang $ARGS -o $out $in $LINK_ARGS
 description = Linking target $out

rule cpp_LINKER
 command = clang++ $ARGS -o $out $in $LINK_ARGS
 description = Linking target $out

rule SHSYM
 command = /data/data/com.termux/files/usr/bin/meson --internal symbolextractor /data/data/com.termux/files/home/pipewire-termux-proot/builddir $in $IMPLIB $out $CROSS
 description = Generating symbol file $out
 restat = 1

# Other rules

rule CUSTOM_COMMAND
 command = $COMMAND
 description = $DESC
 restat = 1

rule CUSTOM_COMMAND_DEP
 command = $COMMAND
 deps = gcc
 depfile = $DEPFILE_UNQUOTED
 description = $DESC
 restat = 1

rule REGENERATE_BUILD
 command = /data/data/com.termux/files/usr/bin/meson --internal regenerate /data/data/com.termux/files/home/pipewire-termux-proot .
 description = Regenerating build files
 generator = 1

# Phony build target, always out of date

build PHONY: phony 

